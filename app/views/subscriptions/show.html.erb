<div class="max-w-sm mx-auto my-8 px-4">
  <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="p-6 text-center border-b border-slate-100">
      <% if @subscription.photo.attached? %>
        <%= image_tag @subscription.photo, class: "h-16 w-16 object-contain mx-auto rounded-xl" %>
      <% else %>
        <div class="h-16 w-16 bg-indigo-50 rounded-xl mx-auto flex items-center justify-center">
          <%= heroicon "credit-card", variant: :outline, options: { class: "h-8 w-8 text-indigo-300" } %>
        </div>
      <% end %>
      <h1 class="mt-3 text-xl font-semibold text-slate-900"><%= @subscription.company_name %></h1>
      <% if @subscription.url.present? %>
        <a href="<%= @subscription.url %>" class="text-xs text-indigo-600 hover:underline mt-0.5 block truncate"><%= @subscription.url %></a>
      <% end %>
    </div>

    <dl class="p-6 space-y-3 text-sm">
      <div class="flex justify-between">
        <dt class="font-medium text-slate-500">Price</dt>
        <dd class="text-slate-900 font-semibold"><%= number_to_currency(@subscription.price) %> <%= @subscription.currency.upcase %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="font-medium text-slate-500">Frequency</dt>
        <dd class="text-slate-900"><%= @subscription.frequency %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="font-medium text-slate-500">Next payment</dt>
        <dd class="text-slate-900"><%= @subscription.payment_date.strftime("%d %b %Y") %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="font-medium text-slate-500">Category</dt>
        <dd class="text-slate-900"><%= @subscription.category.capitalize %></dd>
      </div>
      <% if @subscription.description.present? %>
        <div class="flex justify-between">
          <dt class="font-medium text-slate-500">Description</dt>
          <dd class="text-slate-900 text-right max-w-[60%]"><%= @subscription.description %></dd>
        </div>
      <% end %>
    </dl>

    <div class="px-6 pb-6 flex gap-2">
      <%= link_to edit_subscription_path(@subscription), class: "flex-1 inline-flex justify-center items-center gap-1 px-3 py-2 border border-slate-300 text-slate-700 text-sm rounded-lg hover:bg-slate-50 transition" do %>
        <%= heroicon "pencil-square", variant: :outline, options: { class: "h-4 w-4" } %>
        Edit
      <% end %>
      <%= button_to subscription_path(@subscription), method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "flex-1 inline-flex justify-center items-center gap-1 px-3 py-2 bg-red-50 text-red-600 text-sm rounded-lg hover:bg-red-100 transition" do %>
        <%= heroicon "trash", variant: :solid, options: { class: "h-4 w-4" } %>
        Delete
      <% end %>
    </div>
  </div>

  <%= link_to subscriptions_path, class: "inline-flex items-center gap-1 text-sm text-indigo-600 hover:underline mt-4" do %>
    <%= heroicon "arrow-left", variant: :outline, options: { class: "h-4 w-4" } %>
    Back to Dashboard
  <% end %>
</div>
