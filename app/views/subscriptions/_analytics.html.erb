<%# ── Financial Intelligence Center ── %>
<% analytics = local_assigns[:analytics] %>
<% next_sub  = local_assigns[:next_sub] %>

<% if analytics.count.zero? %>

  <div class="mb-6">
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-8 text-center">
      <p class="text-zinc-500 text-sm mb-5">Add your first subscription to see your financial overview.</p>
      <%= link_to new_subscription_path,
            data: { turbo_frame: "subscription_form" },
            class: "inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-sm font-semibold rounded-xl hover:bg-zinc-100 active:scale-95 transition-all duration-150" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
        </svg>
        Add your first subscription
      <% end %>
    </div>
  </div>

<% else %>

  <%# ── Row 1: 3 hero KPIs ── %>
  <div class="grid grid-cols-3 gap-3 mb-3">

    <%# Monthly Burn Rate %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Monthly</p>
      <p class="text-3xl font-extrabold text-white tabular-nums tracking-tight">
        <%= number_to_currency(analytics.monthly_burn_rate) %>
      </p>
      <p class="text-xs text-zinc-600 mt-2"><%= pluralize(analytics.count, "active subscription") %></p>
    </div>

    <%# Annual Projection %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Annual</p>
      <p class="text-3xl font-extrabold text-zinc-400 tabular-nums tracking-tight">
        <%= number_to_currency(analytics.annual_projection) %>
      </p>
      <p class="text-xs text-zinc-600 mt-2">projected this year</p>
    </div>

    <%# Next Due %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Next Due</p>
      <% if next_sub %>
        <p class="text-3xl font-extrabold text-white tabular-nums tracking-tight">
          <%= next_sub.payment_date.strftime("%b %d") %>
        </p>
        <p class="text-xs text-zinc-600 mt-2 truncate"><%= next_sub.company_name %></p>
      <% else %>
        <p class="text-3xl font-extrabold text-zinc-700">—</p>
      <% end %>
    </div>

  </div>

  <%# ── Row 2: Category breakdown + Avg/sub ── %>
  <div class="grid grid-cols-4 gap-3 mb-3">

    <%# Category Breakdown %>
    <div class="col-span-3 bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-4">By Category</p>
      <div class="space-y-3">
        <% analytics.category_breakdown.each do |item| %>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs font-medium text-zinc-300"><%= item[:category] %></span>
              <span class="text-xs font-semibold text-white tabular-nums">
                <%= number_to_currency(item[:total]) %>
                <span class="text-zinc-600 font-normal ml-1"><%= item[:percentage] %>%</span>
              </span>
            </div>
            <div class="h-1 w-full bg-zinc-800 rounded-full overflow-hidden">
              <div class="h-full bg-white/60 rounded-full transition-all duration-500"
                   style="width: <%= item[:percentage] %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Avg / sub %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6 flex flex-col justify-between">
      <div>
        <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Avg / sub</p>
        <p class="text-2xl font-extrabold text-white tabular-nums tracking-tight">
          <%= number_to_currency(analytics.average_monthly_cost) %>
        </p>
        <p class="text-xs text-zinc-600 mt-1">per month</p>
      </div>
      <% if analytics.top_category %>
        <div class="mt-4 pt-4 border-t border-zinc-800">
          <p class="text-xs text-zinc-600 mb-1">Top category</p>
          <p class="text-sm font-bold text-zinc-300"><%= analytics.top_category[:category] %></p>
          <p class="text-xs text-zinc-600"><%= analytics.top_category[:percentage] %>% of spend</p>
        </div>
      <% end %>
    </div>

  </div>

  <%# ── Insight Banner ── %>
  <div class="bg-zinc-900 border border-zinc-800 rounded-2xl px-5 py-4 flex items-start gap-3 mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
         class="h-4 w-4 text-zinc-500 mt-0.5 shrink-0">
      <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
    </svg>
    <p class="text-xs text-zinc-400 leading-relaxed">
      <% if analytics.top_category && analytics.top_category[:percentage] >= 50 %>
        <span class="text-white font-semibold"><%= analytics.top_category[:category] %></span> accounts for
        <%= analytics.top_category[:percentage] %>% of your monthly spend —
        consider whether all <%= analytics.top_category[:category].downcase %> subscriptions are earning their keep.
      <% elsif analytics.annual_projection > 1200 %>
        Your <%= pluralize(analytics.count, "subscription") %> total
        <span class="text-white font-semibold"><%= number_to_currency(analytics.annual_projection) %> per year</span>.
        Worth reviewing periodically to cut what you don't use.
      <% else %>
        Averaging <span class="text-white font-semibold"><%= number_to_currency(analytics.average_monthly_cost) %>/month</span>
        per subscription across <%= analytics.count %> services.
        Biggest category: <span class="text-white font-semibold"><%= analytics.top_category&.dig(:category) %></span>.
      <% end %>
    </p>
  </div>

<% end %>
