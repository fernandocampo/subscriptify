<%# ── Hero Stats Header ── %>
<% analytics = local_assigns[:analytics] %>
<% next_sub  = local_assigns[:next_sub] %>

<% if analytics.count.zero? %>

  <div class="mb-6">
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-8 text-center">
      <p class="text-zinc-500 text-sm mb-5">Add your first subscription to see your financial overview.</p>
      <%= link_to new_subscription_path,
            data: { turbo_frame: "subscription_form" },
            class: "inline-flex items-center gap-2 px-5 py-2.5 bg-white text-black text-sm font-semibold rounded-xl hover:bg-zinc-100 active:scale-95 transition-all duration-150" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
        </svg>
        Add your first subscription
      <% end %>
    </div>
  </div>

<% else %>

  <div class="grid grid-cols-3 gap-3 mb-6">

    <%# Monthly Spend %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Monthly</p>
      <p class="text-3xl font-extrabold text-white tabular-nums tracking-tight">
        <%= number_to_currency(analytics.monthly_burn_rate) %>
      </p>
      <p class="text-xs text-zinc-600 mt-2"><%= pluralize(analytics.count, "subscription") %></p>
    </div>

    <%# Annual Projection %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Annual</p>
      <p class="text-3xl font-extrabold text-zinc-400 tabular-nums tracking-tight">
        <%= number_to_currency(analytics.annual_projection) %>
      </p>
      <p class="text-xs text-zinc-600 mt-2">projected this year</p>
    </div>

    <%# Next Due %>
    <div class="bg-zinc-900 rounded-2xl border border-zinc-800 p-6">
      <p class="text-xs text-zinc-500 uppercase tracking-widest font-medium mb-3">Next Due</p>
      <% if next_sub %>
        <div class="flex items-center gap-2 flex-wrap">
          <p class="text-3xl font-extrabold text-white tabular-nums tracking-tight">
            <%= next_sub.payment_date.strftime("%b %d") %>
          </p>
          <span class="px-2 py-0.5 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-400 text-xs font-medium">
            <%= next_sub.payment_date.strftime("%Y") %>
          </span>
        </div>
        <p class="text-xs text-zinc-600 mt-2 truncate"><%= next_sub.company_name %></p>
      <% else %>
        <p class="text-3xl font-extrabold text-zinc-700">—</p>
      <% end %>
    </div>

  </div>

<% end %>
