<%# ── Financial Intelligence Center ── %>
<% analytics = local_assigns[:analytics] %>
<% next_sub  = local_assigns[:next_sub] %>

<% if analytics.count.zero? %>

  <%# ── Empty State ── %>
  <div class="mb-6">
    <div class="bg-zinc-900 rounded-3xl p-12 text-center hover:bg-zinc-800 transition-colors duration-200">
      <div class="inline-flex items-center justify-center h-12 w-12 rounded-2xl bg-zinc-800 mb-5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
             class="h-6 w-6 text-zinc-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
        </svg>
      </div>
      <p class="text-zinc-400 text-sm mb-5">Add your subscriptions to unlock your financial intelligence center.</p>
      <%= link_to new_subscription_path,
            data: { turbo_frame: "subscription_form" },
            class: "inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-500 active:scale-95 transition-all duration-150" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
        </svg>
        Add your first subscription to see analytics
      <% end %>
    </div>
  </div>

<% else %>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">

    <%# ── Hero: Monthly Burn Rate ── %>
    <div class="col-span-2 bg-gradient-to-br from-indigo-600 to-indigo-800 rounded-3xl p-6
                hover:from-indigo-500 hover:to-indigo-700 transition-all duration-200 cursor-default">
      <p class="text-xs font-semibold text-indigo-200 uppercase tracking-widest mb-2">Monthly Burn Rate</p>
      <p class="text-4xl font-extrabold text-white tabular-nums tracking-tight">
        <%= number_to_currency(analytics.monthly_burn_rate) %>
      </p>
      <p class="text-xs text-indigo-200 mt-2"><%= pluralize(analytics.count, "active subscription") %></p>
    </div>

    <%# ── Annual Projection ── %>
    <div class="bg-zinc-900 rounded-3xl p-6 hover:bg-zinc-800 transition-colors duration-200 cursor-default">
      <p class="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-2">Annual</p>
      <p class="text-2xl font-extrabold text-white tabular-nums"><%= number_to_currency(analytics.annual_projection) %></p>
      <p class="text-xs text-zinc-500 mt-2">projected</p>
    </div>

    <%# ── Next Due ── %>
    <div class="bg-zinc-900 rounded-3xl p-6 hover:bg-zinc-800 transition-colors duration-200 cursor-default">
      <p class="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-2">Next Due</p>
      <% if next_sub %>
        <p class="text-2xl font-extrabold text-white tabular-nums"><%= next_sub.payment_date.strftime("%b %d") %></p>
        <p class="text-xs text-zinc-500 mt-2 truncate"><%= next_sub.company_name %></p>
      <% else %>
        <p class="text-2xl font-extrabold text-zinc-600">—</p>
      <% end %>
    </div>

    <%# ── Category Breakdown ── %>
    <div class="col-span-2 sm:col-span-3 bg-zinc-900 rounded-3xl p-6 hover:bg-zinc-800 transition-colors duration-200 cursor-default">
      <p class="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-4">By Category</p>
      <div class="space-y-3">
        <% analytics.category_breakdown.each do |item| %>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs font-medium text-zinc-300"><%= item[:category] %></span>
              <span class="text-xs font-semibold text-white tabular-nums">
                <%= number_to_currency(item[:total]) %>
                <span class="text-zinc-500 font-normal ml-1"><%= item[:percentage] %>%</span>
              </span>
            </div>
            <div class="h-1.5 w-full bg-zinc-700 rounded-full overflow-hidden">
              <div class="h-full bg-indigo-400 rounded-full transition-all duration-500"
                   style="width: <%= item[:percentage] %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Avg / sub ── %>
    <div class="col-span-2 sm:col-span-1 bg-zinc-900 rounded-3xl p-6 hover:bg-zinc-800 transition-colors duration-200 cursor-default flex flex-col justify-between">
      <div>
        <p class="text-xs font-semibold text-zinc-400 uppercase tracking-widest mb-2">Avg / sub</p>
        <p class="text-2xl font-extrabold text-white tabular-nums"><%= number_to_currency(analytics.average_monthly_cost) %></p>
        <p class="text-xs text-zinc-500 mt-1">per month</p>
      </div>
      <% if analytics.top_category %>
        <div class="mt-4 pt-4 border-t border-zinc-700">
          <p class="text-xs text-zinc-500 mb-0.5">Top category</p>
          <p class="text-sm font-bold text-indigo-400"><%= analytics.top_category[:category] %></p>
        </div>
      <% end %>
    </div>

    <%# ── Insight Banner ── %>
    <div class="col-span-2 sm:col-span-4 bg-zinc-900 border border-zinc-800 rounded-3xl px-6 py-4
                flex items-start gap-3 hover:bg-zinc-800 transition-colors duration-200">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
           class="h-4 w-4 text-indigo-400 mt-0.5 shrink-0">
        <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
      </svg>
      <p class="text-xs text-zinc-300 leading-relaxed">
        <% if analytics.top_category && analytics.top_category[:percentage] >= 50 %>
          <span class="text-white font-semibold"><%= analytics.top_category[:category] %></span> dominates
          <%= analytics.top_category[:percentage] %>% of your monthly budget —
          consider whether all <%= analytics.top_category[:category].downcase %> subscriptions are earning their keep.
        <% elsif analytics.annual_projection > 1200 %>
          Your <%= pluralize(analytics.count, "subscription") %> add up to
          <span class="text-white font-semibold"><%= number_to_currency(analytics.annual_projection) %> per year</span>.
          That's worth reviewing periodically to cut what you don't use.
        <% else %>
          You're averaging <span class="text-white font-semibold"><%= number_to_currency(analytics.average_monthly_cost) %>/month</span>
          per subscription across <%= analytics.count %> services.
          Your biggest category is <span class="text-white font-semibold"><%= analytics.top_category&.dig(:category) %></span>.
        <% end %>
      </p>
    </div>

  </div>

<% end %>
