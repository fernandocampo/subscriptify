<%# ── Financial Insights Bento Grid ── %>
<% analytics = local_assigns[:analytics] %>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">

  <%# ── Monthly Burn Rate (hero card) ── %>
  <div class="col-span-2 bg-white rounded-2xl border border-zinc-200 p-5">
    <p class="text-xs font-medium text-zinc-400 uppercase tracking-widest mb-1">Monthly Burn Rate</p>
    <p class="text-3xl font-bold text-zinc-900 tabular-nums"><%= number_to_currency(analytics.monthly_burn_rate) %></p>
    <p class="text-xs text-zinc-500 mt-1.5"><%= pluralize(analytics.count, "active subscription") %></p>
  </div>

  <%# ── Annual Projection ── %>
  <div class="bg-white rounded-2xl border border-zinc-200 p-5">
    <p class="text-xs font-medium text-zinc-400 uppercase tracking-widest mb-1">Annual</p>
    <p class="text-xl font-bold text-zinc-900 tabular-nums"><%= number_to_currency(analytics.annual_projection) %></p>
    <p class="text-xs text-zinc-500 mt-1.5">projected</p>
  </div>

  <%# ── Avg Cost per Sub ── %>
  <div class="bg-white rounded-2xl border border-zinc-200 p-5">
    <p class="text-xs font-medium text-zinc-400 uppercase tracking-widest mb-1">Avg / sub</p>
    <p class="text-xl font-bold text-zinc-900 tabular-nums"><%= number_to_currency(analytics.average_monthly_cost) %></p>
    <p class="text-xs text-zinc-500 mt-1.5">per month</p>
  </div>

  <% if analytics.count > 0 %>

    <%# ── Category Breakdown (3 cols on sm) ── %>
    <div class="col-span-2 sm:col-span-3 bg-white rounded-2xl border border-zinc-200 p-5">
      <p class="text-xs font-medium text-zinc-400 uppercase tracking-widest mb-3">By Category</p>
      <% if analytics.category_breakdown.any? %>
        <div class="space-y-2.5">
          <% analytics.category_breakdown.each do |item| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-medium text-zinc-600"><%= item[:category] %></span>
                <span class="text-xs font-semibold text-zinc-900 tabular-nums">
                  <%= number_to_currency(item[:total]) %> &middot; <span class="text-zinc-400"><%= item[:percentage] %>%</span>
                </span>
              </div>
              <div class="h-1.5 w-full bg-zinc-100 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-500 rounded-full transition-all"
                     style="width: <%= item[:percentage] %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-xs text-zinc-400">No category data yet.</p>
      <% end %>
    </div>

    <%# ── Top Category card ── %>
    <div class="col-span-2 sm:col-span-1 bg-white rounded-2xl border border-zinc-200 p-5 flex flex-col justify-between">
      <p class="text-xs font-medium text-zinc-400 uppercase tracking-widest mb-1">Top Category</p>
      <% if analytics.top_category %>
        <div>
          <p class="text-lg font-bold text-zinc-900 leading-tight"><%= analytics.top_category[:category] %></p>
          <p class="text-xs text-zinc-500 mt-0.5"><%= analytics.top_category[:percentage] %>% of spend</p>
        </div>
        <div class="mt-3 h-1.5 w-full bg-zinc-100 rounded-full overflow-hidden">
          <div class="h-full bg-indigo-500 rounded-full"
               style="width: <%= analytics.top_category[:percentage] %>%"></div>
        </div>
      <% else %>
        <p class="text-xl font-bold text-zinc-300">—</p>
      <% end %>
    </div>

    <%# ── Insight banner (full width) ── %>
    <div class="col-span-2 sm:col-span-4 bg-indigo-50 border border-indigo-100 rounded-2xl px-5 py-3.5 flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
           class="h-4 w-4 text-indigo-400 mt-0.5 shrink-0">
        <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" />
      </svg>
      <p class="text-xs text-indigo-700 leading-relaxed">
        <% if analytics.top_category && analytics.top_category[:percentage] >= 50 %>
          <strong><%= analytics.top_category[:category] %></strong> dominates
          <%= analytics.top_category[:percentage] %>% of your monthly budget —
          consider if all <%= analytics.top_category[:category].downcase %> subscriptions are earning their keep.
        <% elsif analytics.annual_projection > 1200 %>
          Your <%= pluralize(analytics.count, "subscription") %> add up to
          <strong><%= number_to_currency(analytics.annual_projection) %> per year</strong>.
          That's worth reviewing periodically to cut what you don't use.
        <% else %>
          You're averaging <strong><%= number_to_currency(analytics.average_monthly_cost) %>/month</strong>
          per subscription across <%= analytics.count %> services.
          Your biggest category is <strong><%= analytics.top_category&.dig(:category) %></strong>.
        <% end %>
      </p>
    </div>

  <% end %>
</div>
