<%= turbo_frame_tag "subscription_form" do %>
  <div class="bg-zinc-900/80 backdrop-blur rounded-2xl border border-zinc-800 p-8 mb-6 max-w-xl mx-auto"
       data-controller="smart-sub">

    <div class="flex items-center justify-between mb-8">
      <h2 class="text-base font-semibold text-white tracking-tight">New Subscription</h2>
      <%= link_to subscriptions_path,
            data: { turbo_frame: "subscription_form" },
            class: "text-zinc-600 hover:text-zinc-300 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
          <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
        </svg>
      <% end %>
    </div>

    <%= simple_form_for @subscription, html: { data: { turbo_frame: "_top" } } do |f| %>

      <% input_class = "w-full bg-zinc-900/50 border border-zinc-800 text-white placeholder:text-zinc-500 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-white/10 focus:border-white/20 transition" %>
      <% select_class = "w-full bg-zinc-900/50 border border-zinc-800 text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-1 focus:ring-white/10 focus:border-white/20 transition appearance-none" %>

      <div class="space-y-4">

        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">Service name</label>
          <%= f.text_field :company_name,
                placeholder: "Netflix, Spotify, GitHub…",
                class: input_class,
                autocomplete: "off",
                autofocus: true,
                data: { smart_sub_target: "name", action: "input->smart-sub#lookup" } %>
          <p class="hidden text-xs text-zinc-500 mt-1.5 px-0.5" data-smart-sub-target="hint"></p>
        </div>

        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">Price</label>
          <div class="grid grid-cols-3 gap-2">
            <%= f.number_field :price,
                  placeholder: "0.00",
                  step: "0.01",
                  min: "0",
                  class: "col-span-2 #{input_class}",
                  data: { smart_sub_target: "price" } %>
            <%= f.select :currency, Subscription::CURRENCIES,
                  { include_blank: false, selected: "USD" },
                  class: select_class %>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">Frequency</label>
            <%= f.select :frequency, Subscription::FREQUENCE,
                  { include_blank: false },
                  class: select_class %>
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">Next payment</label>
            <%= f.date_field :payment_date,
                  class: "#{input_class} text-zinc-300" %>
          </div>
        </div>

        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">Category</label>
          <%= f.select :category, Subscription::CATEGORIES,
                { include_blank: "Select a category" },
                class: select_class,
                data: { smart_sub_target: "category" } %>
        </div>

        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">
            Website <span class="text-zinc-600">optional</span>
          </label>
          <%= f.text_field :url,
                placeholder: "https://",
                class: input_class %>
        </div>

        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 px-0.5">
            Notes <span class="text-zinc-600">optional</span>
          </label>
          <%= f.text_area :description,
                placeholder: "Add any notes…",
                rows: 2,
                class: "#{input_class} resize-none" %>
        </div>

      </div>

      <div class="flex items-center gap-4 mt-6">
        <%= f.button :submit, "Save subscription",
              class: "flex-1 py-3 bg-white text-black text-sm font-semibold rounded-xl hover:bg-zinc-100 active:scale-95 transition-all duration-150" %>
        <%= link_to "Cancel", subscriptions_path,
              data: { turbo_frame: "subscription_form" },
              class: "text-sm text-zinc-500 hover:text-zinc-300 transition px-1" %>
      </div>

    <% end %>
  </div>
<% end %>
