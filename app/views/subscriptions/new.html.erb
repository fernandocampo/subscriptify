<%= turbo_frame_tag "subscription_form" do %>
  <div class="bg-white rounded-2xl border border-zinc-200 p-6 mb-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-base font-semibold text-zinc-900">New Subscription</h2>
      <%= link_to subscriptions_path,
            data: { turbo_frame: "subscription_form" },
            class: "text-zinc-400 hover:text-zinc-600 transition" do %>
        <%= heroicon "x-mark", variant: :mini, options: { class: "h-5 w-5" } %>
      <% end %>
    </div>
    <%= simple_form_for @subscription, html: { data: { turbo_frame: "_top" } } do |f| %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.input :company_name %>
          <p class="text-xs text-zinc-400 -mt-2">Escribe el nombre real (ej: Netflix) y buscaremos el logo por ti.</p>
        </div>
        <%= f.input :description %>
        <%= f.input :url %>
        <%= f.input :payment_date, html5: true %>
        <%= f.input :frequency, collection: Subscription::FREQUENCE %>
        <%= f.input :recurrent %>
        <%= f.input :price %>
        <%= f.input :currency, collection: Subscription::CURRENCIES %>
        <%= f.input :category, collection: Subscription::CATEGORIES %>
      </div>
      <div class="flex items-center gap-3 mt-6">
        <%= f.button :submit, "Save subscription", class: "px-5 py-2 bg-indigo-600 text-white text-sm font-medium rounded-xl hover:bg-indigo-700 transition" %>
        <%= link_to "Cancel", subscriptions_path,
              data: { turbo_frame: "subscription_form" },
              class: "text-sm text-zinc-500 hover:text-zinc-700" %>
      </div>
    <% end %>
  </div>
<% end %>
