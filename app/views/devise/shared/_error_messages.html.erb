<% if resource.errors.any? %>
  <div id="error_explanation" data-turbo-cache="false"
       class="mb-5 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3 text-sm">
    <p class="text-xs font-semibold uppercase tracking-wider text-red-400 mb-1.5">
      <%= I18n.t("errors.messages.not_saved",
                 count: resource.errors.count,
                 resource: resource.class.model_name.human.downcase) %>
    </p>
    <ul class="list-disc list-inside space-y-0.5 text-red-400/80">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
