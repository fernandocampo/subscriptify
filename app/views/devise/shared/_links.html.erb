<%- if controller_name != 'sessions' %>
  <%= link_to "Log in", new_session_path(resource_name),
        class: "text-slate-400 hover:text-indigo-400 transition-colors" %>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "Create an account", new_registration_path(resource_name),
        class: "text-slate-400 hover:text-indigo-400 transition-colors" %>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Forgot your password?", new_password_path(resource_name),
        class: "text-slate-400 hover:text-indigo-400 transition-colors" %>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <%= link_to "Resend confirmation email", new_confirmation_path(resource_name),
        class: "text-slate-400 hover:text-indigo-400 transition-colors" %>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <%= link_to "Resend unlock instructions", new_unlock_path(resource_name),
        class: "text-slate-400 hover:text-indigo-400 transition-colors" %>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider),
          data: { turbo: false },
          class: "w-full inline-flex justify-center items-center px-4 py-2 bg-slate-800 border border-slate-700 text-slate-200 text-sm font-medium rounded-lg hover:bg-slate-700 transition cursor-pointer" %>
  <% end %>
<% end %>
