<div class="max-w-lg mx-auto my-8 px-4">
  <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6">
    <h2 class="text-xl font-semibold text-slate-900 mb-6">Edit <%= resource_name.to_s.humanize %></h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>
      <%= f.input :photo, as: :file %>
      <%= f.input :email %>
      <%= f.input :first_name %>
      <%= f.input :last_name %>
      <%= f.input :phone %>
      <%= f.input :city %>
      <%= f.input :password %>
      <%= f.input :password_confirmation %>
      <%= f.input :current_password %>

      <div class="mt-6 flex items-center gap-3">
        <%= f.button :submit, "Update", class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" %>
        <%= link_to "Back", :back, class: "text-sm text-slate-500 hover:text-slate-700" %>
      </div>
    <% end %>

    <div class="mt-6 pt-6 border-t border-slate-100 text-sm text-slate-500">
      Unhappy?
      <%= link_to "Cancel my account", registration_path(resource_name),
            data: { turbo_confirm: "Are you sure?" },
            method: :delete,
            class: "text-red-600 hover:underline ml-1" %>
    </div>
  </div>
</div>
