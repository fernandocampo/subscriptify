<%# Profile Settings — dark zinc design system %>
<div class="min-h-[calc(100vh-4rem)] flex items-start justify-center px-4 py-16">
  <div class="w-full max-w-xl">

    <%# Page header %>
    <div class="mb-8">
      <p class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-2">Account</p>
      <h1 class="text-3xl font-bold text-white tracking-tight">Profile Settings</h1>
    </div>

    <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), method: :put, multipart: true) do |f| %>

      <%# Validation errors %>
      <% if resource.errors.any? %>
        <div class="mb-5 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3">
          <p class="text-xs font-semibold uppercase tracking-wider text-red-400 mb-1.5">
            <%= pluralize(resource.errors.count, "error") %> prevented saving your profile
          </p>
          <ul class="space-y-0.5 text-sm text-red-400/80 list-disc list-inside">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# ─── Personal info ─────────────────────────────────────── %>
      <div class="bg-zinc-900/50 backdrop-blur-md border border-zinc-800 rounded-2xl p-6 mb-4">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-5">Personal Info</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div>
            <%= f.label :first_name, "First name", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <%= f.text_field :first_name, class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>

          <div>
            <%= f.label :last_name, "Last name", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <%= f.text_field :last_name, class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <%= f.label :phone, "Phone", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <%= f.telephone_field :phone, class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>

          <div>
            <%= f.label :city, "City", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <%= f.text_field :city, class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>
        </div>
      </div>

      <%# ─── Contact ───────────────────────────────────────────── %>
      <div class="bg-zinc-900/50 backdrop-blur-md border border-zinc-800 rounded-2xl p-6 mb-4">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-5">Contact</p>

        <div>
          <%= f.label :email, "Email address", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
          <%= f.email_field :email, autocomplete: "email", class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
        </div>
      </div>

      <%# ─── Avatar ────────────────────────────────────────────── %>
      <div class="bg-zinc-900/50 backdrop-blur-md border border-zinc-800 rounded-2xl p-6 mb-4">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-5">Avatar</p>

        <div>
          <%= f.label :photo, "Profile photo", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
          <%= f.file_field :photo, class: "w-full text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-zinc-800 file:text-zinc-300 hover:file:bg-zinc-700 file:cursor-pointer file:transition-colors file:duration-150 cursor-pointer" %>
        </div>
      </div>

      <%# ─── Security ──────────────────────────────────────────── %>
      <div class="bg-zinc-900/50 backdrop-blur-md border border-zinc-800 rounded-2xl p-6 mb-6">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-500 mb-1">Security</p>
        <p class="text-xs text-zinc-600 mb-5">Leave blank to keep your current password.</p>

        <div class="space-y-4">
          <div>
            <%= f.label :password, "New password", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm new password", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>

          <div class="pt-2 border-t border-zinc-800">
            <%= f.label :current_password, "Current password", class: "block text-xs font-medium uppercase tracking-wider text-zinc-500 mb-1.5" %>
            <p class="text-xs text-zinc-600 mb-1.5">Required to confirm any changes</p>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full bg-zinc-800/60 border border-zinc-700/60 rounded-xl px-4 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 focus:bg-zinc-800 transition-colors duration-150" %>
          </div>
        </div>
      </div>

      <%# ─── Actions ───────────────────────────────────────────── %>
      <div class="flex items-center gap-4 mb-10">
        <%= f.submit "Save changes",
            class: "inline-flex items-center px-6 py-2.5 bg-white text-black text-sm font-semibold rounded-xl hover:bg-zinc-100 active:scale-95 transition-all duration-150 cursor-pointer" %>
        <%= link_to "Cancel", :back,
            class: "text-sm text-zinc-500 hover:text-zinc-300 transition-colors duration-150" %>
      </div>

    <% end %>

    <%# ─── Danger zone ───────────────────────────────────────────── %>
    <div class="border-t border-zinc-800/60 pt-8">
      <p class="text-xs font-medium uppercase tracking-widest text-zinc-600 mb-3">Danger Zone</p>
      <p class="text-xs text-zinc-600 mb-4">
        Once you delete your account, all of your data will be permanently removed. This action cannot be undone.
      </p>
      <%= link_to "Delete my account", registration_path(resource_name),
            data: { turbo_method: :delete, turbo_confirm: "Are you sure? This action is permanent and cannot be undone." },
            class: "inline-flex items-center gap-1.5 text-xs font-medium text-red-500/70 hover:text-red-400 transition-colors duration-150 group" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        Delete my account
      <% end %>
    </div>

  </div>
</div>
