<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <h2 class="text-2xl font-bold text-slate-900 mb-6 text-center">Sign up</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>
      <%= f.input :email %>
      <%= f.input :password %>
      <%= f.input :password_confirmation %>

      <div class="mt-6">
        <%= f.button :submit, "Sign up", class: "w-full inline-flex justify-center items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-slate-500 space-y-1">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
