<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">

    <div class="text-center mb-8">
      <p class="text-xs font-semibold uppercase tracking-widest text-indigo-400 mb-2">Subscriptify</p>
      <h1 class="text-2xl font-bold text-slate-100">Create an account</h1>
      <p class="mt-1 text-sm text-slate-400">Start tracking your subscriptions for free</p>
    </div>

    <div class="rounded-2xl bg-slate-900/50 border border-slate-800 p-8 shadow-2xl backdrop-blur-sm">
      <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages" %>

        <div class="space-y-5">
          <div>
            <%= f.label :email, class: "block text-xs font-medium text-slate-400 mb-1.5 uppercase tracking-wide" %>
            <%= f.email_field :email, autocomplete: "email",
                  placeholder: "you@example.com",
                  class: "w-full rounded-lg bg-slate-900 border border-slate-700 px-3 py-2.5 text-sm text-slate-100 placeholder:text-slate-500 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:ring-offset-2 focus:ring-offset-slate-950 transition" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-xs font-medium text-slate-400 mb-1.5 uppercase tracking-wide" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-slate-500 mb-1.5"><%= @minimum_password_length %> characters minimum</p>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "w-full rounded-lg bg-slate-900 border border-slate-700 px-3 py-2.5 text-sm text-slate-100 placeholder:text-slate-500 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:ring-offset-2 focus:ring-offset-slate-950 transition" %>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-xs font-medium text-slate-400 mb-1.5 uppercase tracking-wide" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "w-full rounded-lg bg-slate-900 border border-slate-700 px-3 py-2.5 text-sm text-slate-100 placeholder:text-slate-500 focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:ring-offset-2 focus:ring-offset-slate-950 transition" %>
          </div>

          <div class="pt-1">
            <%= f.submit "Create account", class: "w-full inline-flex justify-center items-center px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-lg transition cursor-pointer shadow-lg shadow-indigo-500/20" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-6 flex flex-col items-center gap-2 text-sm">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
