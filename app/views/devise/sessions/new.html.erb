<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <h2 class="text-2xl font-bold text-slate-900 mb-6 text-center">Log in</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.input :email, required: false, autofocus: true, input_html: { autocomplete: "email" } %>
      <%= f.input :password, required: false, input_html: { autocomplete: "current-password" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>

      <div class="mt-6">
        <%= f.button :submit, "Log in", class: "w-full inline-flex justify-center items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-slate-500 space-y-1">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
