<div class="min-h-[80vh] flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-sm">
    <h2 class="text-2xl font-bold text-slate-900 mb-6 text-center">Change your password</h2>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>
      <%= f.input :reset_password_token, as: :hidden %>
      <%= f.full_error :reset_password_token %>

      <%= f.input :password, label: "New password", required: true, autofocus: true,
            hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
            input_html: { autocomplete: "new-password" } %>
      <%= f.input :password_confirmation, label: "Confirm your new password", required: true,
            input_html: { autocomplete: "new-password" } %>

      <div class="mt-6">
        <%= f.button :submit, "Change my password", class: "w-full inline-flex justify-center items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-slate-500 space-y-1">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
