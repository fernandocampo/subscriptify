<nav class="fixed top-0 inset-x-0 z-50 bg-white border-b border-slate-200" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <%= link_to root_path, class: "flex-shrink-0" do %>
        <%= image_tag "navlogo.png", class: "h-8 w-auto", alt: "Subscriptify" %>
      <% end %>

      <!-- Desktop nav -->
      <div class="hidden sm:flex sm:items-center sm:gap-6">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", subscriptions_path, class: "text-sm font-medium text-slate-600 hover:text-indigo-600 transition" %>
          <%= link_to "New", new_subscription_path, class: "text-sm font-medium text-slate-600 hover:text-indigo-600 transition" %>
          <%= link_to "Statistics", stats_subscriptions_path, class: "text-sm font-medium text-slate-600 hover:text-indigo-600 transition" %>
          <%= link_to "Profile", profile_path, class: "text-sm font-medium text-slate-600 hover:text-indigo-600 transition" %>
          <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-slate-600 hover:text-red-600 transition" %>
        <% else %>
          <%= link_to "Log in", new_user_session_path, class: "text-sm font-medium text-slate-600 hover:text-indigo-600 transition" %>
          <%= link_to "Sign up", new_user_registration_path, class: "inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition" %>
        <% end %>
      </div>

      <!-- Mobile hamburger -->
      <button class="sm:hidden p-2 rounded-lg text-slate-500 hover:bg-slate-100"
              data-action="click->navbar#toggle"
              aria-label="Open menu">
        <%= heroicon "bars-3", variant: :outline, class: "h-6 w-6" %>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="hidden sm:hidden border-t border-slate-100 bg-white" data-navbar-target="menu">
    <div class="px-4 py-3 space-y-1">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", subscriptions_path, class: "block px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50" %>
        <%= link_to "New Subscription", new_subscription_path, class: "block px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50" %>
        <%= link_to "Statistics", stats_subscriptions_path, class: "block px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50" %>
        <%= link_to "Profile", profile_path, class: "block px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50" %>
        <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-3 py-2 rounded-lg text-sm font-medium text-red-600 hover:bg-red-50" %>
      <% else %>
        <%= link_to "Log in", new_user_session_path, class: "block px-3 py-2 rounded-lg text-sm font-medium text-slate-700 hover:bg-slate-50" %>
        <%= link_to "Sign up", new_user_registration_path, class: "block px-3 py-2 rounded-lg text-sm font-medium text-indigo-600 hover:bg-indigo-50" %>
      <% end %>
    </div>
  </div>
</nav>
