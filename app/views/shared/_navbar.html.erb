<nav class="fixed top-0 inset-x-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800/60" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">

      <%= link_to root_path, class: "flex items-center gap-2.5 flex-shrink-0" do %>
        <span class="h-7 w-7 rounded-full bg-white flex items-center justify-center">
          <span class="text-black text-sm font-black leading-none">S</span>
        </span>
        <span class="font-semibold text-white tracking-tight text-sm">Subscriptify</span>
      <% end %>

      <!-- Desktop nav -->
      <div class="hidden sm:flex sm:items-center sm:gap-6">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", subscriptions_path, class: "text-sm font-medium text-zinc-400 hover:text-white transition-colors duration-150" %>
          <%= link_to "Profile", profile_path, class: "text-sm font-medium text-zinc-400 hover:text-white transition-colors duration-150" %>
          <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm font-medium text-zinc-500 hover:text-red-400 transition-colors duration-150" %>
        <% else %>
          <%= link_to "Log in", new_user_session_path, class: "text-sm font-medium text-zinc-400 hover:text-white transition-colors duration-150" %>
          <%= link_to "Get Started", new_user_registration_path, class: "inline-flex items-center px-4 py-2 bg-white text-black text-sm font-semibold rounded-xl hover:bg-zinc-100 active:scale-95 transition-all duration-150" %>
        <% end %>
      </div>

      <!-- Mobile hamburger -->
      <button class="sm:hidden p-2 rounded-xl text-zinc-500 hover:bg-zinc-800 transition-colors duration-150"
              data-action="click->navbar#toggle"
              aria-label="Open menu">
        <%= heroicon "bars-3", variant: :outline, options: { class: "h-6 w-6" } %>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="hidden sm:hidden border-t border-zinc-800 bg-zinc-950/95 backdrop-blur-md" data-navbar-target="menu">
    <div class="px-6 py-3 space-y-1">
      <% if user_signed_in? %>
        <%= link_to "Dashboard", subscriptions_path, class: "block px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:bg-zinc-800 transition-colors duration-150" %>
        <%= link_to "Profile", profile_path, class: "block px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:bg-zinc-800 transition-colors duration-150" %>
        <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-3 py-2.5 rounded-xl text-sm font-medium text-red-400 hover:bg-zinc-800 transition-colors duration-150" %>
      <% else %>
        <%= link_to "Log in", new_user_session_path, class: "block px-3 py-2.5 rounded-xl text-sm font-medium text-zinc-300 hover:bg-zinc-800 transition-colors duration-150" %>
        <%= link_to "Get Started", new_user_registration_path, class: "block px-3 py-2.5 rounded-xl text-sm font-semibold text-black bg-white hover:bg-zinc-100 transition-colors duration-150" %>
      <% end %>
    </div>
  </div>
</nav>
