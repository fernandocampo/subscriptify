<%= content_for :json_ld do %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Subscriptify",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "url": "https://www.subscriptify.me",
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "USD", "name": "Starter" },
      { "@type": "Offer", "price": "19", "priceCurrency": "USD", "name": "Lifetime Pro" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "2"
    }
  }
  </script>
<% end %>

<!-- Hero -->
<section class="min-h-[88vh] flex items-center justify-center px-6 py-20 text-center bg-white">
