          <%= heroicon "clock", variant: :outline, options: { class: "h-5 w-5 text-amber-600" } %>
        </div>
        <h3 class="text-lg font-bold text-slate-900 tracking-tight">Trial tracking</h3>
        <p class="mt-2 text-slate-500 text-sm leading-relaxed">Track free trials and know exactly when you'll be charged. Cancel before it costs you.</p>
        <div class="mt-4 font-mono text-xs bg-slate-50 rounded-lg p-3 border border-slate-100 space-y-0.5">
          <div class="text-slate-400">// upcoming charge</div>
          <div><span class="text-amber-500 font-semibold">TRIAL</span> Netflix Premium</div>
