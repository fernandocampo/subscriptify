        <span class="text-xs text-slate-400 mt-1">usuarios activos</span>
      </div>
      <div class="flex flex-col items-center px-4">
        <span class="font-mono text-2xl sm:text-3xl font-bold text-slate-900">5 min</span>
        <span class="text-xs text-slate-400 mt-1">para empezar</span>
      </div>
    </div>

  </div>
</section>

