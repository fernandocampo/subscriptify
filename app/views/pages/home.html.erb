                  <span class="font-mono font-bold text-indigo-600">$84.97</span>
                </div>
                <div class="w-full h-1 bg-slate-100 rounded-full overflow-hidden">
                  <div class="h-full bg-indigo-500 rounded-full w-[72%]"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Trial tracking -->
